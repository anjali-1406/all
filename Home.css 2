/* =====================================================
   HOME.CSS (PART 2/4)
   Create Post + Feed Cards + Posts
===================================================== */

/* ===========================
   Create Post Card
=========================== */

.feed-card{
    background:#fff;
    border-radius:12px;
    box-shadow:0 1px 4px rgba(0,0,0,.08);
    margin-bottom:22px;
    overflow:hidden;
}

.create-top{
    display:flex;
    align-items:flex-start;
    gap:12px;
    padding:16px;
}

.user-avatar{
    width:42px;
    height:42px;
    border-radius:50%;
    overflow:hidden;
    background:#e4e6eb;
    display:flex;
    justify-content:center;
    align-items:center;
    flex-shrink:0;
}

.user-avatar img{
    width:100%;
    height:100%;
    object-fit:cover;
}

.create-input{
    flex:1;
    border:none;
    resize:none;
    outline:none;
    font-size:16px;
    line-height:1.5;
    min-height:70px;
}

#create-preview-box,
#image-preview-box{
    padding:0 16px 16px;
}

#image-preview{
    width:100%;
    border-radius:10px;
    object-fit:cover;
    max-height:450px;
}

.create-bottom{
    display:flex;
    justify-content:space-between;
    align-items:center;
    padding:14px 16px;
    border-top:1px solid #eee;
}

.upload-btn{
    cursor:pointer;
    color:#1877f2;
    font-weight:600;
}

.post-btn{
    border:none;
    background:#1877f2;
    color:#fff;
    padding:9px 26px;
    border-radius:8px;
    cursor:pointer;
    font-weight:600;
    transition:.2s;
}

.post-btn:hover{
    background:#166fe5;
}

/* ===========================
   Feed Post
=========================== */

.post-card{
    background:#fff;
    border-radius:12px;
    overflow:hidden;
    box-shadow:0 1px 4px rgba(0,0,0,.08);
}

.post-header{
    display:flex;
    justify-content:space-between;
    align-items:center;
    padding:15px;
}

.post-avatar-container{
    width:42px;
    height:42px;
    border-radius:50%;
    overflow:hidden;
    background:#e4e6eb;
    display:flex;
    justify-content:center;
    align-items:center;
    flex-shrink:0;
}

.post-avatar-container img{
    width:100%;
    height:100%;
    object-fit:cover;
}

.post-author{
    font-size:15px;
    font-weight:700;
    color:#111;
}

.post-time{
    font-size:12px;
    color:#65676b;
}

.follow-btn{
    border:none;
    background:#1877f2;
    color:#fff;
    padding:8px 16px;
    border-radius:6px;
    cursor:pointer;
    font-size:13px;
    font-weight:600;
    transition:.2s;
}

.follow-btn:hover{
    background:#166fe5;
}

.follow-btn.following{
    background:#e4e6eb;
    color:#111;
}

.follow-btn.following:hover{
    background:#dadde1;
}

/* ===========================
   Post Image
=========================== */

.image-frame{
    width:100%;
    background:#000;
}

.post-media{
    width:100%;
    display:block;
    max-height:650px;
    object-fit:contain;
}

/* ===========================
   Caption
=========================== */

.caption-container-box{
    padding:14px 16px 8px;
}

.post-caption-text{
    font-size:15px;
    line-height:1.6;
    color:#111;
    word-break:break-word;
}

/* ===========================
   Edit Form
=========================== */

.inline-edit-form{
    padding:15px;
}

.inline-edit-form textarea{
    width:100%;
    resize:vertical;
    min-height:90px;
    border:1px solid #ddd;
    border-radius:8px;
    padding:10px;
    outline:none;
}
